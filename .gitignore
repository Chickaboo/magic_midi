# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.env/
.venv/

# Jupyter notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Model checkpoints and weights (too large for git)
checkpoints/
*.safetensors
*.pt
*.pth
*.ckpt
*.bin

# Processed data (regenerated automatically)
processed/
*.npy
manifest.json

# Tokenizer (regenerated automatically)
tokenizer/
tokenizer.json

# Training logs (session-specific)
training_log.json
*.log

# Generated MIDI output
generated/
*.mid
*.midi

# Local cache
.session_cache/
session_cache/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V3
.Trashes
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files (may contain secrets)
.env
*.env

# Weights and Biases
wandb/

# Coverage and testing artifacts
.coverage
htmlcov/
.pytest_cache/

# Temporary files
tmp/
temp/
*.tmp

# App virtualenv/runtime artifacts
app/.venv/

# Keep app structure but ignore dropped runtime assets
!app/models/
app/models/*
!app/models/.gitkeep

!app/tokenizer/
app/tokenizer/*
!app/tokenizer/.gitkeep

!app/runtime/
app/runtime/*
!app/runtime/.gitkeep
!app/runtime/outputs/
app/runtime/outputs/*
!app/runtime/outputs/.gitkeep
